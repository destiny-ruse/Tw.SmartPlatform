{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tw.smartplatform.local/schemas/standards-index.schema.json",
  "title": "Standards Generated Index Artifacts",
  "oneOf": [
    {
      "title": "L0 index",
      "type": "object",
      "required": ["schema_version", "generator", "generated_at", "standards"],
      "properties": {
        "schema_version": { "const": "2.0.0" },
        "generator": { "$ref": "#/$defs/generator" },
        "generated_at": { "type": "string" },
        "standards": {
          "type": "array",
          "items": { "$ref": "#/$defs/standardEntry" }
        }
      }
    },
    {
      "title": "L1 shard",
      "type": "object",
      "required": ["schema_version", "generator", "generated_at", "kind", "value", "standards"],
      "properties": {
        "schema_version": { "const": "2.0.0" },
        "generator": { "$ref": "#/$defs/generator" },
        "generated_at": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["role", "stack", "doc-type", "tag"]
        },
        "value": { "type": "string" },
        "standards": {
          "type": "array",
          "items": { "$ref": "#/$defs/l1StandardEntry" }
        }
      }
    },
    {
      "title": "L2 section index",
      "type": "object",
      "required": ["id", "path", "version", "sections"],
      "properties": {
        "id": { "type": "string" },
        "path": { "type": "string" },
        "version": { "type": "string" },
        "sections": {
          "type": "array",
          "items": { "$ref": "#/$defs/section" }
        }
      }
    }
  ],
  "$defs": {
    "generator": {
      "type": "object",
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "standardEntry": {
      "type": "object",
      "required": [
        "id",
        "title",
        "doc_type",
        "status",
        "version",
        "path",
        "roles",
        "stacks",
        "tags",
        "summary",
        "sections_index",
        "shards"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "doc_type": { "type": "string" },
        "status": { "type": "string" },
        "version": { "type": "string" },
        "path": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "stacks": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "sections_index": { "type": "string" },
        "shards": { "type": "array", "items": { "type": "string" } }
      }
    },
    "l1StandardEntry": {
      "type": "object",
      "required": [
        "id",
        "title",
        "doc_type",
        "status",
        "version",
        "path",
        "roles",
        "stacks",
        "tags",
        "summary",
        "sections_index"
      ],
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "doc_type": { "type": "string" },
        "status": { "type": "string" },
        "version": { "type": "string" },
        "path": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "stacks": { "type": "array", "items": { "type": "string" } },
        "tags": { "type": "array", "items": { "type": "string" } },
        "summary": { "type": "string" },
        "sections_index": { "type": "string" }
      }
    },
    "section": {
      "type": "object",
      "required": ["anchor", "title", "level", "start_line", "end_line", "regions"],
      "properties": {
        "anchor": { "type": "string" },
        "title": { "type": "string" },
        "level": { "type": "integer" },
        "start_line": { "type": "integer" },
        "end_line": { "type": "integer" },
        "regions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "start_line", "end_line"],
            "properties": {
              "id": { "type": "string" },
              "start_line": { "type": "integer" },
              "end_line": { "type": "integer" }
            }
          }
        }
      }
    }
  }
}
