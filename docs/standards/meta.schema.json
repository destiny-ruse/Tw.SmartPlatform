{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tw.smartplatform.local/schemas/standard-meta.schema.json",
  "title": "Engineering Standard Metadata v2",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "title",
    "doc_type",
    "status",
    "version",
    "owners",
    "roles",
    "stacks",
    "tags",
    "summary",
    "machine_rules",
    "supersedes",
    "superseded_by",
    "review_after"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*(\\.[a-z][a-z0-9-]*)+$",
      "description": "Repository-unique dotted standard ID."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "doc_type": {
      "type": "string",
      "enum": ["rule", "reference", "process", "decision"]
    },
    "status": {
      "type": "string",
      "enum": ["draft", "active", "deprecated", "superseded"]
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "owners": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": ["architect", "backend", "frontend", "qa", "devops", "ai"]
      }
    },
    "stacks": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["dotnet", "java", "python", "vue-ts", "uniapp"]
      }
    },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9-]*$"
      }
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "machine_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "type"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "path": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 }
        }
      }
    },
    "supersedes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "superseded_by": {
      "type": ["string", "null"]
    },
    "review_after": {
      "type": "string",
      "format": "date"
    }
  }
}
